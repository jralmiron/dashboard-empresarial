# ============================================================
# DASHBOARD EMPRESARIAL — Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env.local
#   2. Rellena TODOS los valores antes de ejecutar el proyecto
#   3. NUNCA subas .env.local al repositorio (está en .gitignore)
#   4. Para producción, configura estas vars en Vercel Dashboard
# ============================================================

# ------------------------------------------------------------
# SUPABASE — Base de datos y autenticación
# Obtener en: https://supabase.com/dashboard/project/[ID]/settings/api
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# DATABASE — Prisma (misma BD de Supabase)
# Obtener en: https://supabase.com/dashboard/project/[ID]/settings/database
# Usar "Transaction" mode (puerto 6543) para serverless
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[ID]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ID]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ------------------------------------------------------------
# SEGURIDAD — Cifrado y tokens
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------
NEXTAUTH_SECRET=genera-un-secret-de-32-bytes-en-hex
ENCRYPTION_KEY=genera-una-clave-de-32-bytes-en-hex
JWT_SECRET=genera-un-jwt-secret-de-32-bytes-en-hex

# ------------------------------------------------------------
# NEXT.JS
# ------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ------------------------------------------------------------
# GOOGLE APIs — Calendar + Gmail + Vision (OCR)
# Obtener en: https://console.cloud.google.com/
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
GOOGLE_CALENDAR_API_KEY=
GOOGLE_VISION_API_KEY=

# ------------------------------------------------------------
# TELEGRAM BOT
# Obtener en: https://t.me/BotFather
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ------------------------------------------------------------
# SENTRY — Monitoreo de errores
# Obtener en: https://sentry.io/settings/[ORG]/projects/[PROJECT]/keys/
# ------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ------------------------------------------------------------
# POSTHOG — Analíticas (opcional)
# Obtener en: https://app.posthog.com/project/settings
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# REDIS — Colas asíncronas (Fase 4 - BullMQ)
# Usar Upstash para producción: https://upstash.com/
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://default:TOKEN@ENDPOINT.upstash.io:6380

# ------------------------------------------------------------
# UPLOADTHING — Subida de archivos (opcional)
# Obtener en: https://uploadthing.com/dashboard
# ------------------------------------------------------------
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# ------------------------------------------------------------
# EMAIL — Para envío transaccional (Fase 4)
# Alternativa a Gmail API: Resend (recomendado para transaccional)
# Obtener en: https://resend.com/api-keys
# ------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@tudominio.com

# ------------------------------------------------------------
# GROQ — IA en producción (plan free: 14.4k tokens/día)
# Obtener en: https://console.groq.com/keys
# ------------------------------------------------------------
GROQ_API_KEY=
