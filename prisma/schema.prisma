// Prisma Schema — Dashboard Empresarial
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  admin
  manager
  staff
  viewer
}

enum EventStatus {
  borrador
  confirmado
  en_curso
  completado
  cancelado
}

enum TaskStatus {
  pendiente
  en_progreso
  revision
  completada
}

enum TaskPriority {
  baja
  media
  alta
  urgente
}

enum BudgetStatus {
  borrador
  enviado
  aprobado
  rechazado
  facturado
}

// ============================================================
// MODELOS BASE
// ============================================================

model Profile {
  id        String    @id @default(uuid())
  userId    String    @unique @map("user_id") // FK a auth.users de Supabase
  email     String    @unique
  fullName  String?   @map("full_name")
  avatarUrl String?   @map("avatar_url")
  role      UserRole  @default(staff)
  phone     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relaciones
  events        Event[]       @relation("EventCreator")
  assignedTasks Task[]        @relation("TaskAssignee")
  createdTasks  Task[]        @relation("TaskCreator")
  clients       Client[]
  budgets       Budget[]

  @@map("profiles")
}

model Event {
  id          String      @id @default(uuid())
  name        String
  description String?
  startDate   DateTime    @map("start_date")
  endDate     DateTime?   @map("end_date")
  location    String?
  capacity    Int?
  status      EventStatus @default(borrador)
  imageUrl    String?     @map("image_url")
  notes       String?
  deletedAt   DateTime?   @map("deleted_at") // soft delete
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // FK
  creatorId String  @map("creator_id")
  clientId  String? @map("client_id")

  // Relaciones
  creator  Profile  @relation("EventCreator", fields: [creatorId], references: [id])
  client   Client?  @relation(fields: [clientId], references: [id])
  tasks    Task[]
  budgets  Budget[]

  @@map("events")
}

model Client {
  id          String    @id @default(uuid())
  name        String
  email       String?
  phone       String?
  company     String?
  address     String?
  notes       String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // FK
  createdById String @map("created_by_id")

  // Relaciones
  createdBy Profile  @relation(fields: [createdById], references: [id])
  events    Event[]
  budgets   Budget[]

  @@map("clients")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(pendiente)
  priority    TaskPriority @default(media)
  dueDate     DateTime?    @map("due_date")
  deletedAt   DateTime?    @map("deleted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // FK
  eventId    String? @map("event_id")
  assigneeId String? @map("assignee_id")
  creatorId  String  @map("creator_id")

  // Relaciones
  event    Event?  @relation(fields: [eventId], references: [id])
  assignee Profile? @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  Profile  @relation("TaskCreator", fields: [creatorId], references: [id])

  @@map("tasks")
}

model Budget {
  id          String       @id @default(uuid())
  number      String       @unique // ej: PRE-2026-001
  title       String
  description String?
  amount      Decimal      @db.Decimal(10, 2)
  tax         Decimal      @default(21) @db.Decimal(5, 2) // IVA %
  status      BudgetStatus @default(borrador)
  validUntil  DateTime?    @map("valid_until")
  notes       String?
  pdfUrl      String?      @map("pdf_url")
  deletedAt   DateTime?    @map("deleted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // FK
  clientId  String? @map("client_id")
  eventId   String? @map("event_id")
  createdById String @map("created_by_id")

  // Relaciones
  client    Client?  @relation(fields: [clientId], references: [id])
  event     Event?   @relation(fields: [eventId], references: [id])
  createdBy Profile  @relation(fields: [createdById], references: [id])

  @@map("budgets")
}
